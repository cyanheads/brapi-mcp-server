# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=localhost           # HTTP host (default: localhost)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_PUBLIC_URL=                  # Public origin behind a TLS-terminating proxy (e.g. https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)
# MCP_ALLOWED_ORIGINS=              # Comma-separated list (HTTP mode). Unset → loopback-only;
                                    # set to '*' to disable Origin validation (browser-facing deploys
                                    # behind a TLS proxy must list their public origin explicitly)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── Server-specific ──────────────────────────────────────────────────
#
# Per-alias env vars — pattern: BRAPI_<ALIAS>_<FIELD>
#
# When the agent calls brapi_connect({ alias: 'cassava' }) without baseUrl/auth,
# the server fills both from BRAPI_CASSAVA_* env vars. Falls back to
# BRAPI_DEFAULT_* when the alias-specific var is unset. Explicit agent input
# always wins over env. Hyphens in alias names map to underscores in env
# (alias 'my-server' → BRAPI_MY_SERVER_*).
#
# Per alias you can set ONE credential family (mixing within an alias errors):
#   USERNAME + PASSWORD                  → mode 'sgn' (Breedbase /token exchange)
#   BEARER_TOKEN                         → mode 'bearer' (pre-obtained access token)
#   API_KEY [+ API_KEY_HEADER]           → mode 'api_key' (default header: Authorization)
#   OAUTH_CLIENT_ID + OAUTH_CLIENT_SECRET → mode 'oauth2' (currently rejected at runtime)
# No credential vars = no auth (public endpoints).

# Default — `brapi_connect()` with no args connects here.
# BRAPI_DEFAULT_BASE_URL=https://test-server.brapi.org/brapi/v2

# Cassavabase (SGN) — `brapi_connect({ alias: 'cassava' })`
# BRAPI_CASSAVA_BASE_URL=https://cassavabase.org/brapi/v2
# BRAPI_CASSAVA_USERNAME=
# BRAPI_CASSAVA_PASSWORD=

# Sweetpotatobase (SGN) — `brapi_connect({ alias: 'sweetpotato' })`
# BRAPI_SWEETPOTATO_BASE_URL=https://sweetpotatobase.org/brapi/v2
# BRAPI_SWEETPOTATO_USERNAME=
# BRAPI_SWEETPOTATO_PASSWORD=

# T3 Wheat (no auth) — `brapi_connect({ alias: 't3wheat' })`
# BRAPI_T3WHEAT_BASE_URL=https://wheat.triticeaetoolbox.org/brapi/v2

# Gigwa (no auth, genotyping-heavy) — `brapi_connect({ alias: 'gigwa' })`
# BRAPI_GIGWA_BASE_URL=https://gigwa.southgreen.fr/gigwa/rest/brapi/v2

# API-key auth example — `brapi_connect({ alias: 'prod' })`
# BRAPI_PROD_BASE_URL=https://my-brapi.example.com/brapi/v2
# BRAPI_PROD_API_KEY=
# BRAPI_PROD_API_KEY_HEADER=X-API-Key

# Pre-obtained bearer token example — `brapi_connect({ alias: 'cgiar' })`
# BRAPI_CGIAR_BASE_URL=https://api.cgiar.example.com/brapi/v2
# BRAPI_CGIAR_BEARER_TOKEN=

# Dataset lifecycle
# BRAPI_DATASET_TTL_SECONDS=86400
# BRAPI_DATASET_STORE_DIR=

# Client behavior
# BRAPI_LOAD_LIMIT=200                  # in-context row cap
# BRAPI_MAX_CONCURRENT_REQUESTS=4       # parallel upstream fan-out cap
# BRAPI_RETRY_MAX_ATTEMPTS=3            # retries on 429/5xx
# BRAPI_RETRY_BASE_DELAY_MS=500         # exponential-backoff base
# BRAPI_REFERENCE_CACHE_TTL_SECONDS=3600

# HTTP behavior
# BRAPI_REQUEST_TIMEOUT_MS=30000
# BRAPI_SEARCH_POLL_TIMEOUT_MS=60000    # total budget for async /search polling
# BRAPI_SEARCH_POLL_INTERVAL_MS=1000    # interval between status checks
# BRAPI_ALLOW_PRIVATE_IPS=false         # dev-only — enables localhost / RFC 1918 targets
