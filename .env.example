# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=localhost           # HTTP host (default: localhost)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_PUBLIC_URL=                  # Public origin behind a TLS-terminating proxy (e.g. https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)
# MCP_ALLOWED_ORIGINS=              # Comma-separated list (HTTP mode). Unset → loopback-only;
                                    # set to '*' to disable Origin validation (browser-facing deploys
                                    # behind a TLS proxy must list their public origin explicitly)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── Server-specific ──────────────────────────────────────────────────

# Default BrAPI connection (optional — users can open a session via the
# brapi_connect tool at runtime instead of pre-configuring here).
# BRAPI_DEFAULT_BASE_URL=https://test-server.brapi.org/brapi/v2

# SGN-family session auth (Cassavabase, Sweetpotatobase, etc.)
# BRAPI_DEFAULT_USERNAME=
# BRAPI_DEFAULT_PASSWORD=

# OAuth2 auth (CGIAR-family)
# BRAPI_DEFAULT_OAUTH_CLIENT_ID=
# BRAPI_DEFAULT_OAUTH_CLIENT_SECRET=

# Static API key (header name defaults to Authorization)
# BRAPI_DEFAULT_API_KEY=
# BRAPI_DEFAULT_API_KEY_HEADER=Authorization

# Dataset lifecycle
# BRAPI_DATASET_TTL_SECONDS=86400
# BRAPI_DATASET_STORE_DIR=

# Client behavior
# BRAPI_LOAD_LIMIT=200                  # in-context row cap
# BRAPI_MAX_CONCURRENT_REQUESTS=4       # parallel upstream fan-out cap
# BRAPI_RETRY_MAX_ATTEMPTS=3            # retries on 429/5xx
# BRAPI_RETRY_BASE_DELAY_MS=500         # exponential-backoff base
# BRAPI_REFERENCE_CACHE_TTL_SECONDS=3600

# HTTP behavior
# BRAPI_REQUEST_TIMEOUT_MS=30000
# BRAPI_SEARCH_POLL_TIMEOUT_MS=60000    # total budget for async /search polling
# BRAPI_SEARCH_POLL_INTERVAL_MS=1000    # interval between status checks
# BRAPI_ALLOW_PRIVATE_IPS=false         # dev-only — enables localhost / RFC 1918 targets
