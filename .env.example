# ── Transport ──────────────────────────────────────────────────────────
# MCP_TRANSPORT_TYPE=stdio          # stdio | http (default: stdio)
# MCP_HTTP_PORT=3010                # HTTP port (default: 3010)
# MCP_HTTP_HOST=localhost           # HTTP host (default: localhost)
# MCP_HTTP_ENDPOINT_PATH=/mcp      # HTTP endpoint path (default: /mcp)
# MCP_PUBLIC_URL=                  # Public origin behind a TLS-terminating proxy (e.g. https://mcp.example.com)

# ── Auth ──────────────────────────────────────────────────────────────
# MCP_AUTH_MODE=none                # none | jwt | oauth (default: none)
# MCP_AUTH_SECRET_KEY=              # JWT secret (required for jwt mode)
# MCP_ALLOWED_ORIGINS=              # Comma-separated list (HTTP mode). Unset → loopback-only;
                                    # set to '*' to disable Origin validation (browser-facing deploys
                                    # behind a TLS proxy must list their public origin explicitly)

# ── Storage ───────────────────────────────────────────────────────────
# STORAGE_PROVIDER_TYPE=in-memory   # in-memory | filesystem | supabase | cloudflare-r2 | cloudflare-kv | cloudflare-d1

# ── Session ──────────────────────────────────────────────────────────
# MCP_SESSION_MODE=stateful         # stateful | stateless (default: stateful)

# ── Logging ───────────────────────────────────────────────────────────
# MCP_LOG_LEVEL=info                # debug | info | notice | warning | error

# ── Telemetry ─────────────────────────────────────────────────────────
# OTEL_ENABLED=false                          # Enable OpenTelemetry (default: false)
# OTEL_EXPORTER_OTLP_ENDPOINT=               # OTLP endpoint URL (e.g., http://localhost:4318)

# ── Server-specific ──────────────────────────────────────────────────
#
# Per-alias env vars — pattern: BRAPI_<ALIAS>_<FIELD>
#
# When the agent calls brapi_connect({ alias: 'bti-cassava' }) without
# baseUrl/auth, the server fills both from BRAPI_BTI_CASSAVA_* env vars.
# Falls back to the built-in registry, then BRAPI_DEFAULT_*, when the
# alias-specific var is unset. Explicit agent input always wins over env.
# Hyphens in alias names map to underscores in env (alias 'my-server' →
# BRAPI_MY_SERVER_*; built-in 'bti-cassava' → BRAPI_BTI_CASSAVA_*).
#
# Per alias you can set ONE credential family (mixing within an alias errors):
#   USERNAME + PASSWORD                  → mode 'sgn' (Breedbase /token exchange)
#   BEARER_TOKEN                         → mode 'bearer' (pre-obtained access token)
#   API_KEY [+ API_KEY_HEADER]           → mode 'api_key' (default header: Authorization)
#   OAUTH_CLIENT_ID + OAUTH_CLIENT_SECRET → mode 'oauth2' (client-credentials → /token exchange; optional OAUTH_TOKEN_URL override)
# No credential vars = no auth (public endpoints).

# Default — `brapi_connect()` with no args connects here.
# BRAPI_DEFAULT_BASE_URL=https://test-server.brapi.org/brapi/v2

# Built-in: Cassavabase (SGN) — `brapi_connect({ alias: 'bti-cassava' })`
# Base URL ships in the built-in registry; uncomment only to attach write creds.
# BRAPI_BTI_CASSAVA_USERNAME=
# BRAPI_BTI_CASSAVA_PASSWORD=

# Built-in: Sweetpotatobase (SGN) — `brapi_connect({ alias: 'bti-sweetpotato' })`
# BRAPI_BTI_SWEETPOTATO_USERNAME=
# BRAPI_BTI_SWEETPOTATO_PASSWORD=

# Built-in: T3 Wheat / Oat / Barley (no auth) — `brapi_connect({ alias: 't3-wheat' })`
# (also 't3-oat', 't3-barley'; all ship in the built-in registry, no env vars needed)

# Gigwa (no auth, genotyping-heavy) — `brapi_connect({ alias: 'gigwa' })`
# BRAPI_GIGWA_BASE_URL=https://gigwa.southgreen.fr/gigwa/rest/brapi/v2

# API-key auth example — `brapi_connect({ alias: 'prod' })`
# BRAPI_PROD_BASE_URL=https://my-brapi.example.com/brapi/v2
# BRAPI_PROD_API_KEY=
# BRAPI_PROD_API_KEY_HEADER=X-API-Key

# Pre-obtained bearer token example — `brapi_connect({ alias: 'cgiar' })`
# BRAPI_CGIAR_BASE_URL=https://api.cgiar.example.com/brapi/v2
# BRAPI_CGIAR_BEARER_TOKEN=

# Dataframe lifecycle
# BRAPI_DATASET_TTL_SECONDS=86400        # TTL for dataframe provenance metadata persisted alongside spilled rows

# Client behavior
# BRAPI_LOAD_LIMIT=1000                 # in-context row cap + upstream pageSize during spillover; pairs with the 50-page spillover ceiling for a 50,000-row dataframe cap
# BRAPI_MAX_CONCURRENT_REQUESTS=4       # parallel upstream fan-out cap
# BRAPI_RETRY_MAX_ATTEMPTS=3            # retries on 429/5xx
# BRAPI_RETRY_BASE_DELAY_MS=500         # exponential-backoff base
# BRAPI_REFERENCE_CACHE_TTL_SECONDS=3600

# HTTP behavior
# BRAPI_REQUEST_TIMEOUT_MS=30000
# BRAPI_SEARCH_POLL_TIMEOUT_MS=60000    # total budget for async /search polling
# BRAPI_SEARCH_POLL_INTERVAL_MS=1000    # interval between status checks
# BRAPI_ALLOW_PRIVATE_IPS=false         # dev-only — enables localhost / RFC 1918 targets

# Write surface
# BRAPI_ENABLE_WRITES=false              # opt-in — registers brapi_submit_observations when true

# Genotype-calls upstream pull limit (operator policy)
#
# Bounds total rows pulled from the upstream BrAPI server in a single
# brapi_find_genotype_calls invocation, protecting upstream from unbounded
# sequential paginated GETs. Default 100,000 rows (≈10 pages at the standard
# pageSize=10,000); maximum 500,000 (≈50 pages, matching the per-query budget
# of other find_* tools). Tune down for cost-sensitive deployments; tune up
# only for upstreams you've confirmed can absorb the load.
#
# BRAPI_GENOTYPE_CALLS_MAX_PULL=100000

# Dataframes (SQL/analytical workspace, backed by the framework's DataCanvas)
#
# DuckDB is mandatory and the only supported provider. `@duckdb/node-api`
# ships as a regular dependency; spilled find_* rows auto-register as
# dataframes named `df_<uuid>`. Not available on Cloudflare Workers.
#
# BRAPI_CANVAS_DROP_ENABLED=false        # opt-in for brapi_dataframe_drop (off by default; dataframes expire via TTL)
# BRAPI_CANVAS_MAX_ROWS=10000            # response cap on brapi_dataframe_query rows
# BRAPI_CANVAS_QUERY_TIMEOUT_MS=30000    # per-query wall-clock timeout

# Dataframe export (CSV/Parquet/JSON file output for human review)
#
# Setting BRAPI_EXPORT_DIR is the opt-in for `brapi_dataframe_export` —
# no separate enable flag. The path is the sandbox root; the framework
# rejects absolute paths and `..` traversal in the agent's filename input.
# Stdio-only: under MCP_TRANSPORT_TYPE=http the tool stays disabled
# regardless of this value (the returned path lives on the server, not
# the user). The entry point bridges this to CANVAS_EXPORT_PATH for the
# framework — operators only need to set the brapi-prefixed name.
#
# BRAPI_EXPORT_DIR=/tmp/brapi-mcp/exports
